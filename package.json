{
  "name": "jarvis-01",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:pipeline": "npm run dev --workspace=apps/pipeline",
    "build:web": "npm run build --workspace=apps/web",
    "build:pipeline": "npm run build --workspace=apps/pipeline",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run generate --workspace=packages/db",
    "db:migrate:dev": "npm run migrate:dev --workspace=packages/db",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=packages/db",
    "db:studio": "npm run studio --workspace=packages/db"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
